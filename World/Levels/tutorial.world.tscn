[sub_resource type="Resource" id="Resource_qmpip"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Hey there kiddo, glad to see you're finally awake!"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_m0waw"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "Ugh... where am I?"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_4kpbg"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "That bird got you something good. Not that you didn't put up a good fight yourself. Pretty impressive. The kind of fight it'd be a lot of time and money to animate, if you wanted to do that for some reason."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_0yeo1"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "I... what... who are you? Where am I? What bird? what's going on?"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_v7g2n"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Okay, I see you need a minute. Gather your composure, remember how to walk and stuff, and meet me up ahead."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_3xsbm"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "What if I just hide in my box until the world makes sense instead?"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_nxln1"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "Alright Mink, I've got some questio-"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_kyeqg"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "[shake rate=20.0 level=5 connected=1][font size=36]Whoah![/font][/shake]"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_jbkvl"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Excuse you, but [i]I[/i], sir, am a [b][i]weasel[/i][/b]"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_k6wms"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "You're as pale as a mink!"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_vdh2l"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "[i]No[/i], I am as pale as a [b]GHOST[/b] on account of being dead, and as such deserving of much more respect than you're givin' me."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_3pwol"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "If we weren't each other's best shot at getting out of this place, I'd be outta h- ... well not outta here, but outta - y'know whatever."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_bovwc"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "I'm sorry. Can you please just tell me what's going on?"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_y8ifv"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Oh yeah, sure, there's nothing I love quite like explaining basic things to a half-concussed Jack-in-the-box."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_nwcnj"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "The short version is that good-fer-nothin' bird dropped you in the middle of a cursed forest."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_pqcq8"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "Cursed? This place doesn't look that bad."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_7rbq2"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Right... 'cause nice forests are full of spectral rodents."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_38cj0"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "On a related note, the most notable curse-like thingy here is that there's [i]no[/i] way to leave this place as long as that bird wants you here. Look at me. [i]No way[/i]"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_7y7yf"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "I... oh."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_u4172"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Yeah. Meet me across the next bridge and I'll tell you my brilliant plan to get us both out of here."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_xrmu0"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "That seems like a really clunky way to move around. Both figurative- and literal-like"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_jfwx8"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "I'm still just a little disoriented. I can move really fast if I get the rhythm down."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_3vg3w"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Still. Tricky gap like this? You might be better off getting out of that box and getting a running start."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_xihjb"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "I'd really rather not. Going outside is what got me into this mess."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_a8wg4"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Suit yourself.  Just don't go expecting me to fish you outta the abyss."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_y7yeh"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "So here's the deal. The forest has been slip up into disconnected areas. Well... not fully disconnected"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_ceykc"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "See, there's gates like the one right here, but you need to have special gems to go through them"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_is278"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "Special... gems... right."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_gsj57"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Look, just go flip that switch over there and I'll show ya. I can't flip it myself on account of my ghostly physique."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_1m2fn"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "You just gotta take that gem, and stick it in your box so the magic knows it's yours now."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_icbk2"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Y'see? Even if I could pick it up, I don't have anywhere to put it to claim it as mine."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_4ahtv"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "How do I put it in my box?"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_28m42"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Whaddya mean, \"How do I -\" It's a box isn't it? Get off it, open the lid, and stick the gem in there."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_7b15v"]
script = ExtResource("11_nxln1")
portrait = ExtResource("12_kyeqg")
text = "Or maybe hide inside the box and just let it go? I don't know your inner workings kid."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_wnjp1"]
script = ExtResource("11_nxln1")
portrait = ExtResource("13_jbkvl")
text = "alright alright"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

