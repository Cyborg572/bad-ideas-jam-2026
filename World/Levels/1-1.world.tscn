[sub_resource type="Resource" id="Resource_2ueds"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("11_pw2m5")
text = "That gem shard looks pretty enticing out there. How spike-proof are you?"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_uiqr5"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("12_p2acv")
text = "I'd rather not find out."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_xj6hr"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("11_pw2m5")
text = "What about your box? Chuck it out there, see how it takes it."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_uyoq8"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("12_p2acv")
text = "It [i]is[/i] pretty indistructable, but what if I can't get it back?"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_rxt3l"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("11_pw2m5")
text = "You teleport to it every time you get too stressed out. I think it'll be [wave amp=50.0 freq=5.0 connected=1]fiiiiiine.[/wave]"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_754be"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("11_pw2m5")
text = "I don't think you're getting over there without some kind of catapult."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_se6c2"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("11_pw2m5")
text = "Hey, maybe we can build one with the spring from your box. It's got a kick when it opens!"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_xg3ej"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("12_p2acv")
text = "That's not funny"
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

[sub_resource type="Resource" id="Resource_7dtya"]
script = ExtResource("10_c2nlh")
portrait = ExtResource("11_pw2m5")
text = "That's the Gem we came for. There might be more ahead, if you're feeling bold,  but we can just take this one and go."
metadata/_custom_type_script = "uid://cxeq256h0bwgt"

